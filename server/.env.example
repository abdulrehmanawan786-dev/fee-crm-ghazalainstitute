# Copy this file to .env and fill in real values. Never commit .env to git.

PORT=4001
NODE_ENV=production

DB_HOST=localhost
DB_PORT=3306
DB_USER=ghazala_fees_user
DB_PASSWORD=change_this_strong_password
DB_NAME=ghazala_fees

# Long random string — generate with: openssl rand -base64 48
JWT_SECRET=change_this_to_a_long_random_string

# How long a login session stays valid
JWT_EXPIRES_IN=12h

# Comma-separated list of allowed origins for CORS (your frontend's URL)
ALLOWED_ORIGIN=https://fees.ghazalainstitute.com
